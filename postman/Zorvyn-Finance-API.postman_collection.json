{
  "info": {
    "_postman_id": "zorvyn-finance-api-001",
    "name": "Zorvyn Finance API",
    "description": "Finance dashboard backend: JWT auth, users/roles, financial records, dashboard analytics.\n\n**Setup:** Import `Zorvyn-Local.postman_environment.json`, select it, run **Auth → Login (admin)** or **Login (viewer)** — the test script saves `token` automatically.\n\n**Roles:** Only **ADMIN** can write records and manage users. **VIEWER** / **ANALYST** read own data unless noted.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "recordId", "value": "" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Liveness check. No auth."
          },
          "response": []
        },
        {
          "name": "Login (viewer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.token) {",
                  "    pm.collectionVariables.set('token', j.token);",
                  "    pm.environment.set('token', j.token);",
                  "  }",
                  "} catch (e) {}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"viewer@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Returns `{ \"token\": \"...\" }`. Test script stores token in collection variable `token`."
          },
          "response": []
        },
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.token) {",
                  "    pm.collectionVariables.set('token', j.token);",
                  "    pm.environment.set('token', j.token);",
                  "  }",
                  "} catch (e) {}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Admin token for protected write operations."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Protected (Bearer)",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
      },
      "item": [
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/me",
            "description": "Current user profile (no password hash)."
          },
          "response": []
        },
        {
          "name": "Users",
          "item": [
            {
              "name": "List users (admin)",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/users?page=1&limit=20",
                "description": "**Admin only.** Paginated list."
              },
              "response": []
            },
            {
              "name": "Get user by id",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/users/{{userId}}",
                "description": "Admin: any id. Non-admin: own id only. Set `userId` variable or paste a UUID."
              },
              "response": []
            },
            {
              "name": "Create user (admin)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password12345\",\n  \"name\": \"New User\",\n  \"role\": \"VIEWER\",\n  \"status\": \"ACTIVE\"\n}"
                },
                "url": "{{baseUrl}}/users",
                "description": "**Admin only.** Roles: VIEWER, ANALYST, ADMIN. Status: ACTIVE, INACTIVE."
              },
              "response": []
            },
            {
              "name": "Patch user",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Name\"\n}"
                },
                "url": "{{baseUrl}}/users/{{userId}}",
                "description": "Self: `name` only. Admin: role, status, email, name."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Records",
          "item": [
            {
              "name": "List records",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/records?page=1&limit=20",
                "description": "Optional query: `userId` (admin), `dateFrom`, `dateTo` (ISO datetime), `category`, `type` (INCOME|EXPENSE)."
              },
              "response": []
            },
            {
              "name": "Get record by id",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/records/{{recordId}}",
                "description": "Set `recordId` from list response."
              },
              "response": []
            },
            {
              "name": "Create record (admin)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"amount\": 100.5,\n  \"type\": \"EXPENSE\",\n  \"category\": \"Food\",\n  \"date\": \"2025-04-01T12:00:00.000Z\",\n  \"notes\": \"Lunch\"\n}"
                },
                "url": "{{baseUrl}}/records",
                "description": "**Admin only.** `userId` = owner of the record."
              },
              "response": []
            },
            {
              "name": "Patch record (admin)",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"amount\": 120,\n  \"notes\": \"Updated\"\n}"
                },
                "url": "{{baseUrl}}/records/{{recordId}}",
                "description": "**Admin only.**"
              },
              "response": []
            },
            {
              "name": "Delete record (admin)",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": "{{baseUrl}}/records/{{recordId}}",
                "description": "**Admin only.** 204 No Content on success."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Dashboard",
          "item": [
            {
              "name": "Summary",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/dashboard/summary",
                "description": "Optional: `userId` (admin), `dateFrom`, `dateTo`. Returns totalIncome, totalExpense, net, scope."
              },
              "response": []
            },
            {
              "name": "By category",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/dashboard/by-category",
                "description": "Category breakdown for the visibility scope."
              },
              "response": []
            },
            {
              "name": "Trends (monthly)",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/dashboard/trends",
                "description": "Monthly buckets (UTC)."
              },
              "response": []
            },
            {
              "name": "Recent",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/dashboard/recent?limit=10",
                "description": "Recent transactions; `limit` 1–50."
              },
              "response": []
            }
          ]
        }
      ]
    }
  ]
}
